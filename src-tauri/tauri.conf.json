{
  "$schema": "https://raw.githubusercontent.com/nickerford/tauri-docs/tauri-v2/references/config.schema.json",
  "productName": "BombPad",
  "version": "0.1.0",
  "identifier": "io.bombpad.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BombPad",
        "width": 960,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
